---
interface Props {
  title: string;
  description: string;
  coverImage: string;
  coverAlt: string;
  slug: string;
  delay?: number;
}
const { title, description, coverImage, coverAlt, slug, delay = 0 } = Astro.props;
---

<a
  href={`/portfolio/${slug}`}
  class="reveal card-lift group block rounded-2xl overflow-hidden bg-white shadow-soft"
  style={`transition-delay: ${delay}ms`}
>
  <div class="img-zoom aspect-[4/5]">
    <img src={coverImage} alt={coverAlt} class="w-full h-full object-cover" loading="lazy" />
  </div>
  <div class="p-5 md:p-6">
    <h3 class="font-display text-xl md:text-2xl">{title}</h3>
    <p class="mt-2 text-sm text-taupe leading-relaxed">{description}</p>
    <span class="mt-3 inline-block text-xs uppercase tracking-[0.22em] text-gold group-hover:translate-x-1 transition-transform duration-500">
      View this gallery &rarr;
    </span>
  </div>
</a>
