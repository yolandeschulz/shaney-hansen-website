---
interface Props {
  title: string;
  text: string;
  href: string;
  image: string;
  imageAlt: string;
  delay?: number;
}
const { title, text, href, image, imageAlt, delay = 0 } = Astro.props;
---

<a
  href={href}
  class="reveal card-lift group block rounded-2xl overflow-hidden bg-white shadow-soft"
  style={`transition-delay: ${delay}ms`}
>
  <div class="img-zoom aspect-[4/3]">
    <img src={image} alt={imageAlt} class="w-full h-full object-cover" loading="lazy" />
  </div>
  <div class="p-6 md:p-7">
    <h3 class="font-display text-2xl">{title}</h3>
    <p class="mt-3 text-sm text-taupe leading-relaxed">{text}</p>
    <span class="mt-4 inline-block text-xs uppercase tracking-[0.22em] text-gold group-hover:translate-x-1 transition-transform duration-500">
      Explore &rarr;
    </span>
  </div>
</a>
