---
/**
 * TestimonialSection — "Kind Words" trust section.
 *
 * Testimonials live in src/content/testimonials/testimonials.json and are
 * edited through Pages CMS. An item is shown only when BOTH:
 *   - published = true
 *   - permissionApproved = true (the client agreed to appear on the website)
 *
 * Optional filtering:
 *   - featuredOnly: show only items marked "featured" (homepage).
 *   - serviceTypes: show only items matching these service types (service pages).
 * The whole section disappears while no real testimonials are approved, so no
 * placeholder or fake content is ever rendered. Google Review buttons appear
 * below the testimonials once the links are configured in Site Settings.
 */
import { getEntry } from 'astro:content';
import SectionHeading from './SectionHeading.astro';
import TestimonialCard from './TestimonialCard.astro';
import GoogleReviewsCTA from './GoogleReviewsCTA.astro';

interface Props {
  heading?: string;
  /** Homepage: show only the small curated "featured" set. */
  featuredOnly?: boolean;
  /** Service pages: show only testimonials for these service types. */
  serviceTypes?: string[];
  /** Show the Read/Leave Google Review buttons under the testimonials. */
  showReviewButtons?: boolean;
}
const {
  heading = 'Client Testimonials and Reviews',
  featuredOnly = false,
  serviceTypes,
  showReviewButtons = true,
} = Astro.props;

const entry = await getEntry('testimonials', 'testimonials');
const all = entry?.data.items ?? [];

const items = all.filter((t: any) => {
  if (!t.published || !t.permissionApproved) return false;
  if (featuredOnly && !t.featured) return false;
  if (serviceTypes && serviceTypes.length > 0 && !serviceTypes.includes(t.serviceType)) return false;
  return true;
});
---

{
  items.length > 0 && (
    <section class="max-w-content mx-auto px-5 md:px-8 my-20 md:my-28">
      <SectionHeading title={heading} align="center" />
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {items.map((t: any, i: number) => (
          <TestimonialCard
            quote={t.quote}
            name={t.name}
            source={t.source}
            rating={t.rating}
            date={t.date}
            serviceType={t.serviceType}
            image={t.image}
            reviewLink={t.reviewLink}
            delay={i * 100}
          />
        ))}
      </div>
      {showReviewButtons && <GoogleReviewsCTA align="center" class="mt-10 reveal" />}
    </section>
  )
}
