---
/**
 * Phone-only sticky contact bar (hidden from md/768px up — desktop is untouched).
 * Two equal actions: Call and WhatsApp. Numbers come from Site Settings.
 * Both are tracked (phone_click / whatsapp_click) — key Google Ads conversions.
 */
import { getEntry } from 'astro:content';

const settingsEntry = await getEntry('site', 'settings');
const settings = (settingsEntry?.data ?? {}) as any;

const tel = `tel:${String(settings.phone ?? '').replace(/\s+/g, '')}`;
const wa = `https://wa.me/${settings.whatsapp}`;
---

<!-- Spacer so page content is never hidden behind the fixed bar -->
<div class="h-16 md:hidden" aria-hidden="true"></div>

<div class="md:hidden fixed bottom-0 inset-x-0 z-30 bg-cream/95 backdrop-blur border-t border-sand px-4 pb-[max(0.625rem,env(safe-area-inset-bottom))] pt-2.5">
  <div class="flex gap-3 max-w-content mx-auto">
    <a
      href={tel}
      class="flex-1 flex items-center justify-center gap-2 rounded-full bg-charcoal text-cream py-3 text-sm tracking-wide min-h-[44px]"
      aria-label="Call Shaney Hansen"
      data-track="phone_click"
      data-track-label="sticky-mobile"
    >
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" />
      </svg>
      Call Shaney
    </a>
    <a
      href={wa}
      class="flex-1 flex items-center justify-center gap-2 rounded-full border border-charcoal text-charcoal py-3 text-sm tracking-wide min-h-[44px]"
      aria-label="WhatsApp Shaney Hansen"
      data-track="whatsapp_click"
      data-track-label="sticky-mobile"
    >
      <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.5 14.4c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.14-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.5 0 1.47 1.07 2.89 1.22 3.09.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.7.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.42.25-.7.25-1.29.18-1.42-.08-.12-.28-.2-.57-.35zM12.04 21.5h-.01a9.4 9.4 0 0 1-4.79-1.31l-.34-.2-3.56.93.95-3.47-.22-.36a9.42 9.42 0 0 1-1.44-5.03c0-5.2 4.24-9.43 9.45-9.43a9.4 9.4 0 0 1 6.68 2.77 9.38 9.38 0 0 1 2.76 6.68c0 5.2-4.24 9.42-9.44 9.42zm8.03-17.46A11.31 11.31 0 0 0 12.04 .7C5.79.7.7 5.79.7 12.05c0 2 .52 3.95 1.52 5.67L.6 23.3l5.71-1.5a11.33 11.33 0 0 0 5.72 1.55h.01c6.25 0 11.34-5.09 11.34-11.35 0-3.03-1.18-5.88-3.31-8.02z" />
      </svg>
      WhatsApp
    </a>
  </div>
</div>
