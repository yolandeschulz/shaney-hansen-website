---
import { getEntry } from 'astro:content';
const settingsEntry = await getEntry('site', 'settings');
const settings = (settingsEntry?.data ?? {}) as any;

const nav = [
  { label: 'Home', href: '/' },
  { label: 'Photography', href: '/photography' },
  { label: 'Social Media', href: '/social-media' },
  { label: 'Creative Direction', href: '/creative-direction' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Destination', href: '/destination' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => (href === '/' ? current === '/' : current.startsWith(href));
---

<header class="sticky top-0 z-40 bg-cream/90 backdrop-blur border-b border-sand">
  <div class="max-w-content mx-auto px-5 md:px-8 flex items-center justify-between h-16 md:h-20">
    <a href="/" class="flex flex-col justify-center" aria-label="Shaney Hansen — home">
      <img
        src={settings.logo ?? '/images/general/shaney-hansen-logo-transparent.png'}
        alt="Shaney Hansen Photography"
        class="h-9 md:h-11 w-auto object-contain"
        width="752"
        height="416"
      />
      <span
        class="block whitespace-nowrap text-[0.5rem] md:text-[0.6rem] uppercase tracking-[0.26em] text-taupe mt-0.5 pl-0.5"
        >Lichtenburg &amp; Destination Photographer</span
      >
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-6" aria-label="Main navigation">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm tracking-wide transition-colors duration-300 hover:text-gold',
              isActive(item.href) ? 'text-gold' : 'text-charcoal',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href={`tel:${String(settings.phone ?? '').replace(/\s+/g, '')}`}
        class="flex items-center gap-1.5 text-sm tracking-wide text-charcoal hover:text-gold transition-colors duration-300 border-l border-sand pl-6"
        aria-label="Call Shaney Hansen"
        data-track="phone_click"
        data-track-label="header"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        <span class="sr-only">Call Shaney Hansen: {settings.phone}</span>
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      class="lg:hidden p-2 -mr-2"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="lg:hidden hidden border-t border-sand bg-cream px-5 pb-6 pt-3"
    aria-label="Mobile navigation"
  >
    <ul class="flex flex-col gap-1">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'block py-2.5 text-base border-b border-sand/70 transition-colors',
                isActive(item.href) ? 'text-gold' : 'text-charcoal',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
    <!-- No Call/WhatsApp buttons here: the sticky bar at the bottom of the
         screen already provides both on phones — avoids a wall of buttons. -->
  </nav>
</header>

<script is:inline>
  document.addEventListener('astro:page-load', function () {
    var btn = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;
    btn.addEventListener('click', function () {
      var open = menu.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    });
  });
</script>
