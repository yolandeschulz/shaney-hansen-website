---
import Button from './Button.astro';

interface Props {
  name: string;
  whoFor?: string;
  expect?: string;
  packageDetails?: string;
  image?: string;
  imageAlt?: string;
  reverse?: boolean;
  id?: string;
  /** Optional link to a dedicated service page. */
  link?: string;
  /** Descriptive anchor text for the dedicated-page link (SEO-friendly). */
  linkLabel?: string;
}
const { name, whoFor, expect, packageDetails, image, imageAlt, reverse = false, id, link, linkLabel } =
  Astro.props;
---

<article
  id={id}
  class:list={[
    'reveal grid gap-8 md:grid-cols-2 md:items-center scroll-mt-28',
    reverse && 'md:[&>div:first-child]:order-2',
  ]}
>
  {
    image && (
      <div class="img-zoom rounded-2xl overflow-hidden shadow-soft aspect-[4/3]">
        <img src={image} alt={imageAlt ?? name} class="w-full h-full object-cover" loading="lazy" />
      </div>
    )
  }
  <div>
    <h3 class="font-display text-2xl md:text-3xl">{name}</h3>
    {whoFor && <p class="mt-3 text-taupe leading-relaxed">{whoFor}</p>}
    {expect && <p class="mt-3 leading-relaxed">{expect}</p>}
    {
      packageDetails && (
        <p class="mt-4 text-sm text-taupe bg-sand/60 rounded-lg px-4 py-3 inline-block">
          {packageDetails}
        </p>
      )
    }
    <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3">
      <Button href="/contact" variant="outline" track="service_cta_click" trackLabel={name}>
        Enquire About Availability
      </Button>
      {
        link && (
          <a
            href={link}
            class="text-sm tracking-wide text-charcoal underline underline-offset-4 decoration-sand hover:text-gold transition-colors"
          >
            {linkLabel ?? `More about ${name.toLowerCase()}`} &rarr;
          </a>
        )
      }
    </div>
  </div>
</article>
