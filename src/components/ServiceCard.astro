---
import Button from './Button.astro';

interface Props {
  name: string;
  whoFor?: string;
  expect?: string;
  packageDetails?: string;
  image?: string;
  imageAlt?: string;
  reverse?: boolean;
  id?: string;
}
const { name, whoFor, expect, packageDetails, image, imageAlt, reverse = false, id } = Astro.props;
---

<article
  id={id}
  class:list={[
    'reveal grid gap-8 md:grid-cols-2 md:items-center scroll-mt-28',
    reverse && 'md:[&>div:first-child]:order-2',
  ]}
>
  {
    image && (
      <div class="img-zoom rounded-2xl overflow-hidden shadow-soft aspect-[4/3]">
        <img src={image} alt={imageAlt ?? name} class="w-full h-full object-cover" loading="lazy" />
      </div>
    )
  }
  <div>
    <h3 class="font-display text-2xl md:text-3xl">{name}</h3>
    {whoFor && <p class="mt-3 text-taupe leading-relaxed">{whoFor}</p>}
    {expect && <p class="mt-3 leading-relaxed">{expect}</p>}
    {
      packageDetails && (
        <p class="mt-4 text-sm text-taupe bg-sand/60 rounded-lg px-4 py-3 inline-block">
          {packageDetails}
        </p>
      )
    }
    <div class="mt-6">
      <Button href="/contact" variant="outline">Enquire About Availability</Button>
    </div>
  </div>
</article>
