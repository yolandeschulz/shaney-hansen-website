---
import Button from './Button.astro';

interface Props {
  headline: string;
  support?: string;
  image: string;
  imageAlt: string;
  primaryCta?: string;
  primaryLink?: string;
  secondaryCta?: string;
  secondaryLink?: string;
  compact?: boolean;
  /** CSS object-position value, e.g. "center 20%" — tune which part of the image survives cropping. */
  focalPoint?: string;
  /** Optional short, looping video (mp4). The image is used as poster + reduced-motion fallback.
      Autoplays muted (browser policy); a speaker button lets visitors turn sound on. */
  video?: string;
  videoWebm?: string;
  /** Analytics event names for the CTA buttons (see src/lib/analytics.ts EVENTS). */
  primaryTrack?: string;
  secondaryTrack?: string;
  /** Home page only: overlay the white brand logo over the upper portion of the hero.
      Decorative (aria-hidden) — the text brand in the header remains the accessible name. */
  overlayLogo?: boolean;
  /** Source for the overlay logo (white/cream transparent version). */
  overlayLogoImage?: string;
}
const {
  headline,
  support,
  image,
  imageAlt,
  primaryCta,
  primaryLink = '/contact',
  secondaryCta,
  secondaryLink = '/portfolio',
  compact = false,
  focalPoint,
  video,
  videoWebm,
  primaryTrack,
  secondaryTrack,
  overlayLogo = false,
  overlayLogoImage = '/images/general/shaney-hansen-logo-white.png',
} = Astro.props;
const showOverlayLogo = overlayLogo && !compact;
const focalStyle = focalPoint ? `object-position: ${focalPoint}` : undefined;
---

<!-- Layered hero: full-bleed image with an offset, overlapping text panel.
     Text panel rises softly on load; image has a warm gradient overlay. -->
<section class:list={['relative', compact ? 'pb-10' : 'pb-16 md:pb-24']}>
  <div class="relative img-zoom hero-kenburns">
    <img
      src={image}
      alt={imageAlt}
      class:list={[
        'w-full object-cover',
        compact ? 'h-[46vh] min-h-[320px] max-h-[560px]' : 'h-[62vh] min-h-[420px] md:h-[74vh] max-h-[860px]',
      ]}
      style={focalStyle}
      fetchpriority="high"
    />
    {
      video && (
        <video
          class="absolute inset-0 w-full h-full object-cover motion-reduce:hidden"
          style={focalStyle}
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          poster={image}
        >
          {videoWebm && <source src={videoWebm} type="video/webm" />}
          <source src={video} type="video/mp4" />
        </video>
      )
    }
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal/35 via-charcoal/5 to-transparent pointer-events-none" aria-hidden="true"></div>
    {
      showOverlayLogo && (
        <div
          class="hero-logo reveal pointer-events-none absolute left-1/2 top-[18%] md:top-[21%] -translate-x-1/2 z-[5] w-[70%] max-w-[320px] md:max-w-[460px] lg:max-w-[480px]"
          aria-hidden="true"
        >
          <div
            class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[135%] h-[160%] rounded-full"
            style="background: radial-gradient(closest-side, rgba(46,42,38,0.15), rgba(46,42,38,0) 70%);"
          >
          </div>
          <img
            src={overlayLogoImage}
            alt=""
            width="752"
            height="416"
            class="relative w-full h-auto select-none"
            style="filter: drop-shadow(0 6px 20px rgba(46,42,38,0.5));"
          />
        </div>
      )
    }
    {
      video && (
        <button
          type="button"
          class="hero-sound absolute bottom-5 right-5 z-10 rounded-full bg-charcoal/55 hover:bg-charcoal/80 text-cream p-3 backdrop-blur transition-colors motion-reduce:hidden"
          aria-label="Turn sound on"
          aria-pressed="false"
        >
          <svg class="icon-muted" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M11 5 6 9H3v6h3l5 4V5z" />
            <line x1="16" y1="9" x2="22" y2="15" />
            <line x1="22" y1="9" x2="16" y2="15" />
          </svg>
          <svg class="icon-sound hidden" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M11 5 6 9H3v6h3l5 4V5z" />
            <path d="M15.5 8.5a5 5 0 0 1 0 7" />
            <path d="M18.5 5.5a9 9 0 0 1 0 13" />
          </svg>
        </button>
      )
    }
  </div>

  <div class="max-w-content mx-auto px-5 md:px-8">
    <div
      class="reveal is-visible-on-load relative -mt-20 md:-mt-28 max-w-2xl bg-cream/95 backdrop-blur rounded-2xl shadow-soft px-7 py-9 md:px-12 md:py-12"
    >
      <h1 class="font-display text-3xl md:text-5xl leading-tight">{headline}</h1>
      {support && <p class="mt-5 text-taupe leading-relaxed md:text-lg">{support}</p>}
      {
        (primaryCta || secondaryCta) && (
          <div class="mt-8 flex flex-wrap gap-4 items-center">
            {primaryCta && <Button href={primaryLink} track={primaryTrack}>{primaryCta}</Button>}
            {secondaryCta && (
              <Button href={secondaryLink} variant="outline" track={secondaryTrack}>
                {secondaryCta}
              </Button>
            )}
          </div>
        )
      }
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('astro:page-load', function () {
    document.querySelectorAll('.hero-sound').forEach(function (btn) {
      var wrap = btn.parentElement;
      var vid = wrap ? wrap.querySelector('video') : null;
      if (!vid) return;
      btn.addEventListener('click', function () {
        vid.muted = !vid.muted;
        if (!vid.muted) {
          vid.volume = 1;
          vid.play().catch(function () {});
        }
        btn.setAttribute('aria-pressed', String(!vid.muted));
        btn.setAttribute('aria-label', vid.muted ? 'Turn sound on' : 'Turn sound off');
        btn.querySelector('.icon-muted').classList.toggle('hidden', !vid.muted);
        btn.querySelector('.icon-sound').classList.toggle('hidden', vid.muted);
      });
    });
  });
</script>
