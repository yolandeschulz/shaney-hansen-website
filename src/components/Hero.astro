---
import Button from './Button.astro';

interface Props {
  headline: string;
  support?: string;
  image: string;
  imageAlt: string;
  primaryCta?: string;
  primaryLink?: string;
  secondaryCta?: string;
  secondaryLink?: string;
  compact?: boolean;
  /** CSS object-position value, e.g. "center 20%" — tune which part of the image survives cropping. */
  focalPoint?: string;
  /** Optional short, muted, looping video (mp4). The image is used as poster + reduced-motion fallback. */
  video?: string;
  videoWebm?: string;
}
const {
  headline,
  support,
  image,
  imageAlt,
  primaryCta,
  primaryLink = '/contact',
  secondaryCta,
  secondaryLink = '/portfolio',
  compact = false,
  focalPoint,
  video,
  videoWebm,
} = Astro.props;
const focalStyle = focalPoint ? `object-position: ${focalPoint}` : undefined;
---

<!-- Layered hero: full-bleed image with an offset, overlapping text panel.
     Text panel rises softly on load; image has a warm gradient overlay. -->
<section class:list={['relative', compact ? 'pb-10' : 'pb-16 md:pb-24']}>
  <div class="relative img-zoom hero-kenburns">
    <img
      src={image}
      alt={imageAlt}
      class:list={[
        'w-full object-cover',
        compact ? 'h-[46vh] min-h-[320px] max-h-[560px]' : 'h-[62vh] min-h-[420px] md:h-[74vh] max-h-[860px]',
      ]}
      style={focalStyle}
      fetchpriority="high"
    />
    {
      video && (
        <video
          class="absolute inset-0 w-full h-full object-cover motion-reduce:hidden"
          style={focalStyle}
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          poster={image}
          aria-hidden="true"
        >
          {videoWebm && <source src={videoWebm} type="video/webm" />}
          <source src={video} type="video/mp4" />
        </video>
      )
    }
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal/35 via-charcoal/5 to-transparent" aria-hidden="true"></div>
  </div>

  <div class="max-w-content mx-auto px-5 md:px-8">
    <div
      class="reveal is-visible-on-load relative -mt-20 md:-mt-28 max-w-2xl bg-cream/95 backdrop-blur rounded-2xl shadow-soft px-7 py-9 md:px-12 md:py-12"
    >
      <h1 class="font-display text-3xl md:text-5xl leading-tight">{headline}</h1>
      {support && <p class="mt-5 text-taupe leading-relaxed md:text-lg">{support}</p>}
      {
        (primaryCta || secondaryCta) && (
          <div class="mt-8 flex flex-wrap gap-4 items-center">
            {primaryCta && <Button href={primaryLink}>{primaryCta}</Button>}
            {secondaryCta && (
              <Button href={secondaryLink} variant="outline">
                {secondaryCta}
              </Button>
            )}
          </div>
        )
      }
    </div>
  </div>
</section>
