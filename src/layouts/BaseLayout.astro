---
import { ViewTransitions } from 'astro:transitions';
import { getEntry } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileCallBar from '../components/MobileCallBar.astro';
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** When true, emit <meta name="robots" content="noindex, follow"> (e.g. the 404 page). */
  noindex?: boolean;
  /** Extra JSON-LD objects (e.g. Service, BreadcrumbList) rendered on this page. */
  schemas?: Record<string, unknown>[];
}

const settingsEntry = await getEntry('site', 'settings');
const settings = settingsEntry?.data ?? {};

const {
  title = settings.defaultSeoTitle,
  description = settings.defaultSeoDescription,
  ogImage = settings.defaultOgImage,
  noindex = false,
  schemas = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;

// Only real (non-placeholder) social links belong in sameAs.
const sameAs = [settings.facebook, settings.instagram].filter(
  (u: unknown) => typeof u === 'string' && u.length > 0 && !u.startsWith('[')
);

// LocalBusiness / ProfessionalService schema — the global business identity.
const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': 'https://shaneyhansen.com/#business',
  name: settings.siteName,
  description: settings.defaultSeoDescription,
  url: Astro.site?.href,
  logo: new URL(settings.logo ?? '/favicon.png', Astro.site).href,
  image: new URL(settings.defaultOgImage ?? '/images/og-image.jpg', Astro.site).href,
  telephone: settings.phone,
  email: settings.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: settings.streetAddress,
    addressLocality: settings.addressLocality ?? 'Lichtenburg',
    postalCode: settings.postalCode,
    addressRegion: settings.addressRegion ?? 'North West',
    addressCountry: settings.addressCountry ?? 'ZA',
  },
  areaServed: [
    'Lichtenburg',
    'Mahikeng',
    'Klerksdorp',
    'North West',
    'Pretoria',
    'South Africa',
    'United States',
    'International (selected destinations)',
  ],
  ...(sameAs.length ? { sameAs } : {}),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={settings.siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    {ogImage === settings.defaultOgImage && (
      <>
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    )}
    <meta property="og:image:alt" content="Shaney Hansen Photography — Lichtenburg & destination photographer" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Karla:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    {schemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}

    <!-- Analytics & tracking: inert until real IDs are added in Site Settings.
         See ANALYTICS_MONTHLY_REPORTING_GUIDE.md. -->
    <Analytics />
    <ViewTransitions />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Phone-only sticky Call/WhatsApp bar (hidden from 768px up) -->
    <MobileCallBar />

    <!-- Scroll-reveal system: soft, slow entrances. Fully disabled for
         prefers-reduced-motion (elements simply appear). Re-runs after
         every View Transition navigation. -->
    <script is:inline>
      function initReveals() {
        var els = document.querySelectorAll('.reveal:not(.is-visible)');
        if (!els.length) return;
        var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduced || !('IntersectionObserver' in window)) {
          els.forEach(function (el) {
            el.classList.add('is-visible');
          });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -6% 0px' }
        );
        els.forEach(function (el) {
          io.observe(el);
        });
      }
      document.addEventListener('astro:page-load', initReveals);
    </script>
  </body>
</html>
