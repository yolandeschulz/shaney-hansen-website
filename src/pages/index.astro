---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
import ServicePillarCard from '../components/ServicePillarCard.astro';
import GalleryCategoryCard from '../components/GalleryCategoryCard.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import GoogleReviewsCTA from '../components/GoogleReviewsCTA.astro';
import CTASection from '../components/CTASection.astro';

const page = await getEntry('pages', 'home');
const d = page!.data as any;

const settingsEntry = await getEntry('site', 'settings');
const settings = (settingsEntry?.data ?? {}) as any;
const wa = (msg?: string) =>
  `https://wa.me/${settings.whatsapp}${msg ? `?text=${encodeURIComponent(msg)}` : ''}`;
// Homepage primary CTA is WhatsApp (the primary conversion action).
const heroPrimaryLink = d.heroWhatsappText ? wa(d.heroWhatsappText) : d.heroPrimaryLink;

// Priority services: editable in Pages CMS ("Home page"). Each links to its own
// dedicated, SEO-targeted service page.
const priority = (d.priority ?? []).map((p: any) => ({
  title: p.title,
  text: p.text,
  href: p.href,
  image: p.image,
  imageAlt: p.imageAlt,
}));

const galleries = await getCollection('galleries');
const featured = galleries
  .filter((g) => g.data.featuredOnHomepage)
  .sort((a, b) => a.data.order - b.data.order);
const previewImages = galleries
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6)
  .map((g) => ({ src: g.data.coverImage, alt: g.data.coverAlt, slug: g.id.replace('.json', '') }));

// Pillar cards: editable in Pages CMS ("Home page"). Fallbacks equal the
// original values so the rendered site is unchanged if a field is empty.
const pillars = [
  {
    title: d.pillar1Title ?? 'Photography',
    text: d.pillar1Text ?? 'Warm, natural, story-led photography for weddings, families, maternity, newborns, schools, sport, corporates, studio and styled sessions.',
    href: '/photography',
    image: d.pillar1Image ?? '/images/front-page/placeholder-1.jpg',
    imageAlt: d.pillar1ImageAlt ?? 'Photography by Shaney Hansen — warm and natural',
  },
  {
    title: d.pillar2Title ?? 'Creative Direction & Styled Setups',
    text: d.pillar2Text ?? 'Shaney can help create the full look and feel of a shoot — concepts, styling, prop work and sets built by her own hands.',
    href: '/creative-direction',
    image: d.pillar2Image ?? '/images/creative-direction/cover.jpg',
    imageAlt: d.pillar2ImageAlt ?? 'Styled photography session by Shaney Hansen',
  },
  {
    title: d.pillar3Title ?? 'Social Media Content Creation',
    text: d.pillar3Text ?? 'Photography-led social media content and management for brands, teams and businesses that need to show up consistently and beautifully online.',
    href: '/social-media',
    image: d.pillar3Image ?? '/images/social-media/cover.jpg',
    imageAlt: d.pillar3ImageAlt ?? 'Social media content creation by Shaney Hansen',
  },
];
---

<BaseLayout title={d.seoTitle} description={d.seoDescription} ogImage="/images/og-image.jpg">
  <!-- 1. Hero -->
  <Hero
    overlayLogo
    focalPoint={d.heroFocal}
    focalPointMobile={d.heroFocalMobile}
    video={d.heroVideo}
    videoWebm={d.heroVideoWebm}
    headline={d.heroHeadline}
    support={d.heroSupport}
    image={d.heroImage}
    imageAlt={d.heroImageAlt}
    primaryCta={d.heroPrimaryCta}
    primaryLink={heroPrimaryLink}
    primaryTrack="whatsapp_click"
    secondaryCta={d.heroSecondaryCta}
    secondaryLink={d.heroSecondaryLink}
  />

  <!-- 2. Positioning intro -->
  <section class="max-w-content mx-auto px-5 md:px-8 my-16 md:my-24">
    <SectionHeading eyebrow="Shaney Hansen" title={d.introHeading} text={d.introText} align="center" />
  </section>

  <!-- 2b. Priority services — the highest-value work, each linking to its own page -->
  {
    priority.length > 0 && (
      <section class="max-w-content mx-auto px-5 md:px-8 my-16 md:my-24">
        <SectionHeading eyebrow="Photography" title={d.priorityHeading} text={d.priorityText} />
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {priority.map((p: any, i: number) => (
            <ServicePillarCard {...p} delay={i * 120} />
          ))}
        </div>
        {d.priorityMore?.length > 0 && (
          <p class="reveal mt-8 text-sm text-taupe">
            {d.priorityMoreLabel ?? 'Also available:'}{' '}
            {d.priorityMore.map((m: any, i: number) => (
              <>
                {i > 0 && <span class="text-sand"> · </span>}
                <a href={m.href} class="text-charcoal underline underline-offset-4 decoration-sand hover:text-gold transition-colors">
                  {m.label}
                </a>
              </>
            ))}
          </p>
        )}
      </section>
    )
  }

  <!-- 2c. Proof strip — concise, factual reasons to choose Shaney -->
  {
    d.proofItems?.length > 0 && (
      <section class="bg-sand/50 py-12 md:py-16 my-16 md:my-24">
        <div class="max-w-content mx-auto px-5 md:px-8">
          <h2 class="reveal font-display text-2xl md:text-3xl text-center">{d.proofHeading ?? 'Why clients choose Shaney'}</h2>
          <ul class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 max-w-4xl mx-auto">
            {d.proofItems.map((item: string, i: number) => (
              <li
                class="reveal flex items-start gap-3 bg-white rounded-xl shadow-soft px-5 py-4 text-sm"
                style={`transition-delay: ${(i % 3) * 80}ms`}
              >
                <span class="text-gold mt-0.5">&#10022;</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- 3. Three service pillars -->
  <section class="max-w-content mx-auto px-5 md:px-8 my-16 md:my-24">
    <SectionHeading eyebrow="Services" title={d.pillarsHeading} />
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {pillars.map((p, i) => <ServicePillarCard {...p} delay={i * 120} />)}
    </div>
  </section>

  <!-- 4. Featured photography categories -->
  <section class="bg-sand/60 py-16 md:py-24 my-16 md:my-24">
    <div class="max-w-content mx-auto px-5 md:px-8">
      <SectionHeading eyebrow="Portfolio" title={d.featuredHeading} text={d.featuredText} />
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          featured.map((g, i) => (
            <GalleryCategoryCard
              title={g.data.title}
              description={g.data.description}
              coverImage={g.data.coverImage}
              coverAlt={g.data.coverAlt}
              coverFocal={g.data.coverFocal}
              slug={g.id.replace('.json', '')}
              delay={(i % 3) * 120}
            />
          ))
        }
      </div>
      <div class="mt-10 reveal">
        <Button href="/portfolio" variant="outline">View the Full Portfolio</Button>
      </div>
    </div>
  </section>

  <!-- 5. Creative set-building teaser (layered editorial composition) -->
  <section class="max-w-content mx-auto px-5 md:px-8 my-16 md:my-24 grid gap-10 md:grid-cols-2 md:items-center">
    <div class="reveal relative">
      <div class="img-zoom rounded-2xl overflow-hidden shadow-soft aspect-[4/3]">
        <img
          src={d.creativeImage ?? '/images/styled/cover.jpg'}
          alt={d.creativeImageAlt ?? 'Styled photography session with creative set design'}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
      <div
        class="img-zoom hidden md:block absolute -bottom-10 -right-6 w-48 rounded-2xl overflow-hidden shadow-lift border-4 border-cream"
      >
        <img
          src={d.creativeImageSmall ?? '/images/cake-smash/cover.jpg'}
          alt={d.creativeImageSmallAlt ?? 'Cake smash setup built by Shaney Hansen'}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
    <div class="reveal" style="transition-delay: 150ms">
      <SectionHeading eyebrow="Creative Direction" title={d.creativeHeading} text={d.creativeText} />
      <div class="mt-6">
        <Button href="/creative-direction" variant="outline">Explore Styled Shoots</Button>
      </div>
    </div>
  </section>

  <!-- 6. Social media teaser -->
  <section class="max-w-content mx-auto px-5 md:px-8 my-16 md:my-24 grid gap-10 md:grid-cols-2 md:items-center">
    <div class="md:order-2 reveal relative">
      <div class="img-zoom rounded-2xl overflow-hidden shadow-soft aspect-[4/3]">
        <img
          src={d.socialImage ?? '/images/social-media/cover.jpg'}
          alt={d.socialImageAlt ?? 'Social media content creation by Shaney Hansen'}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="absolute -top-6 -left-4 w-28 h-28 rounded-full bg-blush-soft -z-10" aria-hidden="true"></div>
    </div>
    <div class="md:order-1 reveal" style="transition-delay: 150ms">
      <SectionHeading eyebrow="Social Media" title={d.socialHeading} text={d.socialText} />
      <div class="mt-6">
        <Button href="/social-media" variant="outline">Explore Social Media Management</Button>
      </div>
    </div>
  </section>

  <!-- 7. Destination teaser (layered background + warm overlay) -->
  <section class="relative my-16 md:my-24">
    <div class="absolute inset-0">
      <img
        src={d.destinationImage ?? '/images/front-page/placeholder-3.jpg'}
        alt={d.destinationImageAlt ?? 'Destination lifestyle photography by Shaney Hansen'}
        aria-hidden="true"
        class="w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-charcoal/55"></div>
    </div>
    <div class="relative max-w-content mx-auto px-5 md:px-8 py-20 md:py-28 text-cream">
      <div class="reveal max-w-2xl">
        <p class="text-xs uppercase tracking-[0.28em] text-blush">Destination</p>
        <h2 class="mt-3 font-display text-3xl md:text-4xl leading-snug">{d.destinationHeading}</h2>
        <p class="mt-4 leading-relaxed text-cream/85">{d.destinationText}</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href="/destination" track="destination_enquiry_click" trackLabel="homepage_teaser">
            Explore Destination Photography
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. Portfolio preview strip -->
  <section class="max-w-content mx-auto px-5 md:px-8 my-16 md:my-24">
    <SectionHeading eyebrow="A glimpse" title="From the portfolio" align="center" />
    <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
      {
        previewImages.map((img, i) => (
          <a
            href={`/portfolio/${img.slug}`}
            class="reveal img-zoom rounded-xl overflow-hidden shadow-soft aspect-square block"
            style={`transition-delay: ${i * 80}ms`}
          >
            <img src={img.src} alt={img.alt} class="w-full h-full object-cover" loading="lazy" />
          </a>
        ))
      }
    </div>
  </section>

  <!-- 9. How it works -->
  <section class="max-w-content mx-auto px-5 md:px-8 my-16 md:my-24">
    <SectionHeading eyebrow="The experience" title={d.howHeading} text={d.howText} align="center" />
    <ol class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        (d.howSteps ?? []).map((step: any, i: number) => (
          <li
            class="reveal bg-white rounded-2xl shadow-soft p-7 text-center"
            style={`transition-delay: ${i * 120}ms`}
          >
            <span class="font-display text-4xl text-blush">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="mt-3 font-display text-xl">{step.title}</h3>
            <p class="mt-2 text-sm text-taupe leading-relaxed">{step.text}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- 10. Trust / testimonials: homepage shows only the small curated "featured" set
       (hidden until real, approved testimonials are published) -->
  <TestimonialSection heading={d.trustHeading} featuredOnly showReviewButtons={false} />

  <!-- Google Reviews trust buttons: appear automatically once the review links
       are added in Site Settings (nothing renders while they are placeholders) -->
  <section class="max-w-content mx-auto px-5 md:px-8 my-16 md:my-20">
    <GoogleReviewsCTA align="center" class="reveal" />
  </section>

  <!-- 11. Final CTA -->
  <CTASection heading={d.finalCtaHeading} text={d.finalCtaText} buttonLabel={d.finalCtaButton} />
</BaseLayout>
