---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
import CTASection from '../components/CTASection.astro';

const page = await getEntry('pages', 'about');
const d = page!.data as any;
---

<BaseLayout title={d.seoTitle} description={d.seoDescription} ogImage={d.heroImage}>
  <!-- Editorial overlapping-image intro -->
  <section class="max-w-content mx-auto px-5 md:px-8 pt-14 md:pt-20 grid gap-12 md:grid-cols-2 md:items-center">
    <div class="reveal relative">
      <div class="img-zoom rounded-2xl overflow-hidden shadow-soft aspect-[4/5]">
        <img src={d.heroImage} alt={d.heroImageAlt} class="w-full h-full object-cover" />
      </div>
      <div
        class="img-zoom hidden md:block absolute -bottom-10 -right-8 w-52 rounded-2xl overflow-hidden shadow-lift border-4 border-cream"
      >
        <img
          src={d.secondaryImage ?? '/images/front-page/placeholder-2.jpg'}
          alt={d.secondaryImageAlt ?? 'Photography by Shaney Hansen'}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="absolute -top-6 -left-5 w-24 h-24 rounded-full bg-blush-soft -z-10" aria-hidden="true"></div>
    </div>
    <div class="reveal" style="transition-delay: 150ms">
      <p class="text-xs uppercase tracking-[0.28em] text-gold">About Shaney</p>
      <h1 class="mt-3 font-display text-4xl md:text-5xl leading-tight">{d.heroHeadline}</h1>
      <p class="mt-5 text-taupe leading-relaxed">{d.introText}</p>
      {
        (d.bio ?? '')
          .split('\n\n')
          .filter(Boolean)
          .map((para: string) => <p class="mt-4 leading-relaxed">{para}</p>)
      }
    </div>
  </section>

  <!-- Style -->
  <section class="max-w-content mx-auto px-5 md:px-8 my-16 md:my-24">
    <SectionHeading eyebrow="Her style" title={d.styleHeading} text={d.styleText} />
    <p class="reveal mt-5 max-w-2xl leading-relaxed">{d.creativeText}</p>
  </section>

  <!-- What to expect -->
  <section class="bg-sand/60 py-16 md:py-20 my-16 md:my-24">
    <div class="max-w-content mx-auto px-5 md:px-8">
      <SectionHeading eyebrow="The experience" title={d.expectHeading} />
      <ul class="mt-8 grid gap-3 md:grid-cols-2 max-w-4xl">
        {
          (d.expectItems ?? []).map((item: string, i: number) => (
            <li
              class="reveal flex items-start gap-3 bg-white rounded-xl shadow-soft px-5 py-4 text-sm"
              style={`transition-delay: ${(i % 2) * 90}ms`}
            >
              <span class="text-gold mt-0.5">&#10022;</span>
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Why choose -->
  <section class="max-w-content mx-auto px-5 md:px-8 my-16 md:my-24">
    <SectionHeading eyebrow="Why people choose Shaney" title={d.whyHeading} text={d.whyText} />
    <div class="mt-7 reveal">
      <Button href="/contact">{d.ctaText}</Button>
    </div>
  </section>

  <CTASection
    heading={d.ctaSectionHeading ?? "Let's capture your story"}
    text={d.ctaSectionText ?? 'From family seasons to brand stories — enquiring is simple, safe and personal.'}
  />
</BaseLayout>
