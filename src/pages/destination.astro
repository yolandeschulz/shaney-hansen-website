---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
import CTASection from '../components/CTASection.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import FAQSection from '../components/FAQSection.astro';

const page = await getEntry('pages', 'destination');
const p = page!.data as any;
const svc = await getEntry('services', 'destination');
const d = svc!.data as any;

const settingsEntry = await getEntry('site', 'settings');
const settings = (settingsEntry?.data ?? {}) as any;
const waLink = `https://wa.me/${settings.whatsapp}${
  p.whatsappText ? `?text=${encodeURIComponent(p.whatsappText)}` : ''
}`;

const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://shaneyhansen.com';
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Destination & Travel Photography',
  description: p.seoDescription,
  serviceType: 'Destination Photography',
  url: pageUrl,
  provider: { '@id': `${siteUrl}/#business` },
  areaServed: ['South Africa', 'United States', 'Texas', 'Europe', 'International (selected destinations)'],
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Destination', item: pageUrl },
  ],
};
---

<BaseLayout
  title={p.seoTitle}
  description={p.seoDescription}
  ogImage={p.heroImage}
  schemas={[serviceSchema, breadcrumbSchema]}
>
  <Hero
    focalPoint={p.heroFocal}
    focalPointMobile={p.heroFocalMobile}
    headline={p.heroHeadline}
    support={p.heroSupport}
    image={p.heroImage}
    imageAlt={p.heroImageAlt}
    primaryCta={p.cta}
    primaryLink={waLink}
    primaryTrack="destination_whatsapp_click"
    compact
  />

  <!-- International Quality, South African Value -->
  <section class="max-w-content mx-auto px-5 md:px-8 my-16 md:my-24">
    <SectionHeading eyebrow="Why Shaney" title={d.sectionTitle} />
    <p class="mt-6 reveal max-w-3xl leading-relaxed text-charcoal/90">{d.valueCopy}</p>
  </section>

  <!-- The service -->
  <section class="bg-sand/60 py-16 md:py-20 my-16 md:my-24">
    <div class="max-w-content mx-auto px-5 md:px-8 grid gap-10 md:grid-cols-2 md:items-start">
      <div class="reveal">
        <SectionHeading eyebrow="The service" title={d.title} text={`${d.intro} ${d.body}`} />
        <p class="mt-5 text-taupe leading-relaxed">{d.styledMomentsCopy}</p>
        <div class="mt-7">
          <Button href="/contact" track="international_quote_click" trackLabel="destination_service">
            {d.cta}
          </Button>
        </div>
      </div>
      <div>
        <h3 class="reveal font-display text-xl mb-4">Ideal for</h3>
        <ul class="grid gap-2.5 sm:grid-cols-2">
          {
            (d.idealFor ?? []).map((item: string, i: number) => (
              <li
                class="reveal flex items-start gap-2.5 bg-white rounded-lg shadow-soft px-4 py-3 text-sm"
                style={`transition-delay: ${(i % 2) * 80}ms`}
              >
                <span class="text-gold">&#10022;</span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- Practical details placeholders -->
  <section class="max-w-content mx-auto px-5 md:px-8 my-16 md:my-24">
    <SectionHeading
      eyebrow="Planning"
      title="Travel & destination bookings — how it works"
      text="Destination bookings are kept simple and transparent, so your quote fits your trip, your story and your deliverables."
    />
    <ul class="mt-8 grid gap-3 sm:grid-cols-2 max-w-3xl">
      {
        (d.placeholders ?? []).map((item: string) => (
          <li class="reveal text-sm text-taupe bg-sand/60 rounded-lg px-4 py-3">{item}</li>
        ))
      }
    </ul>
  </section>

  <!-- Trust: only wedding / travel / lifestyle / content testimonials belong here -->
  <TestimonialSection
    serviceTypes={['Destination Lifestyle & Content Photography', 'Wedding Photography', 'Couples Photography']}
  />

  <!-- FAQ: travel and destination questions international clients ask first -->
  <FAQSection categories={['destination', 'bookings']} limit={4} moreLink />

  <CTASection
    heading={p.ctaSectionHeading ?? 'Planning something far from home?'}
    text={p.ctaSectionText ?? 'Tell Shaney about the trip, the occasion and the story you want documented.'}
    buttonLabel={d.cta}
    buttonTrack="destination_enquiry_click"
  />
</BaseLayout>
