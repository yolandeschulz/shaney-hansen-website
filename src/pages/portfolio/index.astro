---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import GalleryCategoryCard from '../../components/GalleryCategoryCard.astro';
import CTASection from '../../components/CTASection.astro';

const galleries = (await getCollection('galleries')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Photography Portfolio | Shaney Hansen Photography"
  description="View natural, story-led wedding, family, newborn, school, corporate, studio and destination photography by Shaney Hansen."
>
  <section class="max-w-content mx-auto px-5 md:px-8 pt-14 md:pt-20">
    <SectionHeading
      as="h1"
      eyebrow="Portfolio"
      title="Natural photographs, real connection and stories worth keeping"
      text="From weddings and family seasons to styled concepts and corporate branding — explore each gallery to see Shaney's warm, natural, story-led style."
      align="center"
    />
  </section>

  <section class="max-w-content mx-auto px-5 md:px-8 mt-12 md:mt-16">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        galleries.map((g, i) => (
          <GalleryCategoryCard
            title={g.data.title}
            description={g.data.description}
            coverImage={g.data.coverImage}
            coverAlt={g.data.coverAlt}
              coverFocal={(g.data as any).coverFocal}
            slug={g.id.replace('.json', '')}
            delay={(i % 3) * 100}
          />
        ))
      }
    </div>
    <p class="reveal mt-10 text-sm text-taupe">
      Ready to book? Read more about
      <a href="/wedding-photographer" class="text-charcoal underline underline-offset-4 decoration-sand hover:text-gold transition-colors">wedding photography</a>,
      <a href="/corporate-photographer" class="text-charcoal underline underline-offset-4 decoration-sand hover:text-gold transition-colors">corporate photography</a> and
      <a href="/school-photographer" class="text-charcoal underline underline-offset-4 decoration-sand hover:text-gold transition-colors">school photography</a>.
    </p>
  </section>

  <CTASection
    heading="See a style you love?"
    text="Enquire about availability for your own session — locally or as a destination project."
    buttonLabel="Book Your Session"
  />
</BaseLayout>
