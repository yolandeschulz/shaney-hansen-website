---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
import CTASection from '../components/CTASection.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import FAQSection from '../components/FAQSection.astro';

// Only photography-related testimonials belong on this page.
const photographyServiceTypes = [
  'Wedding Photography', 'Couples Photography', 'Family Photography', 'Maternity Photography',
  'Newborn Photography', 'Cake Smash Photography', 'School Photography', 'Pre-school Photography',
  'Sport Photography', 'Corporate Photography', 'Studio Session', 'Styled Session',
  'Destination Lifestyle & Content Photography',
];

const entry = await getEntry('services', 'photography');
const d = entry!.data as any;
const services = d.services ?? [];
const slugify = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');

const settingsEntry = await getEntry('site', 'settings');
const settings = (settingsEntry?.data ?? {}) as any;
const waLink = `https://wa.me/${settings.whatsapp}${
  d.heroWhatsappText ? `?text=${encodeURIComponent(d.heroWhatsappText)}` : ''
}`;
---

<BaseLayout
  title={d.seoTitle ?? 'Photography Services in Lichtenburg | Shaney Hansen'}
  description={d.seoDescription ??
    'Explore wedding, family, maternity, newborn, school, corporate, studio and destination photography by Shaney Hansen in Lichtenburg and beyond.'}
  ogImage={d.heroImage ?? '/images/weddings/cover.jpg'}
>
  <Hero
    headline={d.title}
    support={d.intro}
    image={d.heroImage ?? '/images/weddings/cover.jpg'}
    imageAlt={d.heroImageAlt ?? 'Wedding photography by Shaney Hansen'}
    primaryCta={d.heroPrimaryCta ?? 'Enquire on WhatsApp'}
    primaryLink={waLink}
    primaryTrack="whatsapp_click"
    secondaryCta={d.heroSecondaryCta ?? 'View Portfolio'}
    secondaryLink="/portfolio"
    compact
  />

  <!-- Quick jump nav -->
  <nav class="max-w-content mx-auto px-5 md:px-8 mt-4 mb-14 reveal" aria-label="Photography services">
    <ul class="flex flex-wrap gap-2">
      {
        services.map((s: any) => (
          <li>
            <a
              href={`#${slugify(s.name)}`}
              class="inline-block rounded-full border border-sand bg-white px-4 py-1.5 text-xs tracking-wide text-taupe hover:border-gold hover:text-gold transition-colors"
            >
              {s.name}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="max-w-content mx-auto px-5 md:px-8 space-y-20 md:space-y-28">
    {
      services.map((s: any, i: number) => (
        <ServiceCard
          id={slugify(s.name)}
          name={s.name}
          whoFor={s.whoFor}
          expect={s.expect}
          packageDetails={s.packageDetails}
          image={s.image}
          imageAlt={s.imageAlt}
          link={s.link}
          linkLabel={s.linkLabel}
          reverse={i % 2 === 1}
        />
      ))
    }
  </div>

  <!-- Pricing: personal quotes -->
  <section class="bg-sand/60 py-16 md:py-20 my-16 md:my-24">
    <div class="max-w-content mx-auto px-5 md:px-8">
      <SectionHeading eyebrow="Pricing" title={d.pricingHeading} text={d.pricingText} />
      <p class="reveal mt-6 max-w-2xl text-sm text-taupe italic">{d.pricingNote}</p>
      <div class="mt-8 reveal">
        <Button href="/contact">{d.pricingCta ?? 'Request Your Quote'}</Button>
      </div>
    </div>
  </section>

  <!-- Trust: photography testimonials (hidden until real, approved testimonials exist) -->
  <TestimonialSection serviceTypes={photographyServiceTypes} />

  <!-- FAQ: the most common pre-booking questions for photography sessions -->
  <FAQSection categories={['photography', 'bookings']} limit={4} moreLink />

  <CTASection
    heading={d.ctaSectionHeading ?? 'Ready to plan your session?'}
    text={d.ctaSectionText ?? 'Share what you have in mind and Shaney will help shape it into a session that feels like you.'}
  />
</BaseLayout>
