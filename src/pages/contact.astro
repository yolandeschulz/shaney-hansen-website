---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactForm from '../components/ContactForm.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import GoogleReviewsCTA from '../components/GoogleReviewsCTA.astro';

const page = await getEntry('pages', 'contact');
const d = page!.data as any;
const settingsEntry = await getEntry('site', 'settings');
const settings = settingsEntry?.data ?? {};
---

<BaseLayout title={d.seoTitle} description={d.seoDescription}>
  <section class="max-w-content mx-auto px-5 md:px-8 pt-14 md:pt-20">
    <SectionHeading eyebrow="Contact" title={d.heroHeadline} text={d.heroSupport} align="center" />
  </section>

  <section class="max-w-content mx-auto px-5 md:px-8 mt-12 md:mt-16 grid gap-10 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <ContactForm consentText={d.consentText} />
    </div>

    <aside class="space-y-6">
      <div class="reveal bg-white rounded-2xl shadow-soft p-7">
        <h2 class="font-display text-xl">Direct contact</h2>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a
              href={`https://wa.me/${settings.whatsapp}`}
              class="hover:text-gold transition-colors"
              data-track="whatsapp_click"
              data-track-label="contact_aside"
              >Phone / WhatsApp: {settings.phone}</a
            >
          </li>
          <li>
            <a
              href={`mailto:${settings.email}`}
              class="hover:text-gold transition-colors"
              data-track="email_click"
              data-track-label="contact_aside"
              >{settings.email}</a
            >
          </li>
          <li class="text-taupe">{settings.location}</li>
        </ul>
      </div>
      <div class="reveal bg-sand/70 rounded-2xl p-7 text-sm text-taupe leading-relaxed" style="transition-delay: 120ms">
        <p>{settings.travelNote}</p>
        <p class="mt-3">{settings.availabilityLine}.</p>
      </div>
      <a
        href={`https://wa.me/${settings.whatsapp}`}
        class="reveal block text-center rounded-2xl bg-charcoal text-cream px-6 py-5 font-display text-lg transition-all duration-500 hover:bg-taupe"
        style="transition-delay: 200ms"
        data-track="whatsapp_click"
        data-track-label="contact_banner"
      >
        Prefer chatting? WhatsApp Shaney directly &rarr;
      </a>
      <!-- Google Reviews trust buttons: appear once review links are added in Site Settings.
           Renders nothing while the links are still placeholders. -->
      <GoogleReviewsCTA class="reveal" />
    </aside>
  </section>

  <!-- Trust section after the enquiry form (hidden until real, approved testimonials exist) -->
  <TestimonialSection />
</BaseLayout>
