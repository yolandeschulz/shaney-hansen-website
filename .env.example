# Copy this file to .env and fill in real values. Never commit .env.
#
# STATUS: domain registered, hosting active, email created (July 2026).
# The website itself is NOT deployed yet. See PRE_LAUNCH_CHECKLIST.md.

# Final website domain, used for SEO canonical URLs and the sitemap.
SITE_URL="https://shaneyhansen.com"

# ---------------------------------------------------------------------------
# Xneelo hosting reference. Deployment credentials belong in GitHub Secrets
# (see XNEELO_DEPLOYMENT_GUIDE.md), never in this file or in code.
# ---------------------------------------------------------------------------
# Xneelo account owner:        Shaney Hansen (her own account)
# Hosting package:             Basic (South Africa)
# FTP/SFTP/SSH details:        [to be confirmed — store as GitHub Secrets]
# Web root path:               [to be confirmed — usually /public_html/]
# Email address:               hello@shaneyhansen.com (bookings@/shaney@ optional later)
# Mail settings:               IMAP mail.shaneyhansen.com:993 / SMTP smtp.shaneyhansen.com:465 (SSL)
# SSL setup:                   [to be enabled — Let's Encrypt via konsoleH]

# Contact form endpoint (Formspree, Web3Forms, PHP mailer URL, or custom).
# Leave empty to fall back to a mailto: draft + WhatsApp buttons.
# Note: the live form endpoint used by the site is set in
# src/content/site/settings.json (formEndpoint) so it is editable via Pages CMS.
FORM_ENDPOINT="[to be added]"

# ---------------------------------------------------------------------------
# Analytics & tracking placeholders.
# The LIVE values used by the site are read from src/content/site/settings.json
# (editable through Pages CMS), so tracking can be connected without a rebuild.
# These env vars exist as a reference / optional build-time override.
# Tracking only activates when a real ID is present — placeholders in
# square brackets are ignored and nothing is loaded.
# ---------------------------------------------------------------------------

# Google Tag Manager container ID (preferred tracking container), e.g. GTM-XXXXXXX
GTM_ID="[to be added]"

# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX
GA_MEASUREMENT_ID="[to be added]"

# Google Search Console site verification token (content of the meta tag)
GOOGLE_SITE_VERIFICATION="[to be added]"

# Google Ads conversion tracking (do NOT activate until campaigns are planned)
GOOGLE_ADS_CONVERSION_ID="[to be added later]"
GOOGLE_ADS_CONVERSION_LABEL="[to be added later]"

# Meta (Facebook/Instagram) Pixel — only if specifically requested later
META_PIXEL_ID="[optional later]"
